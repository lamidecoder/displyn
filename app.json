{
  "expo": {
    "name": "Displyn",
    "slug": "displyn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "displyn",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.displyn.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSMicrophoneUsageDescription": "Displyn uses your microphone so you can add tasks by voice.",
        "NSPhotoLibraryAddUsageDescription": "Displyn saves share card images to your photo library.",
        "NSPhotoLibraryUsageDescription": "Displyn needs photo library access to save share cards."
      },
      "buildNumber": "1",
      "requireFullScreen": true,
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.displyn.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ],
      "versionCode": 1
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#7C3AED"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Displyn needs access to your photos so you can pick a background for your share card.",
          "cameraPermission": "Displyn needs access to your camera so you can take a photo for your share card."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Displyn needs access to your gallery to save share cards.",
          "savePhotosPermission": "Displyn needs permission to save your share card images.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/a588bc89-0de5-4c95-a4d1-842bae315c12"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a588bc89-0de5-4c95-a4d1-842bae315c12"
      }
    }
  }
}